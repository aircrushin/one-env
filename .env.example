# oneenv environment variables
# Copy this file to .env and replace values.

# Required: sha256 hash of your admin password.
# Generate with:
# node -e "console.log(require('crypto').createHash('sha256').update('your-password').digest('hex'))"
ONEENV_ADMIN_PASSWORD_HASH=

# Required: random secret used to sign session cookies.
ONEENV_SESSION_SECRET=

# Optional local fallback (not recommended in production).
# Used only when ONEENV_ADMIN_PASSWORD_HASH is empty.
ONEENV_ADMIN_PASSWORD=

# Optional: set to production for secure cookie flag.
NODE_ENV=development

# Optional: Notion storage. If omitted, app uses in-memory fallback.
NOTION_API_TOKEN=
NOTION_DATABASE_ID=
# Optional: parent page used by scripts/setup-notion-database.mjs when creating a new database.
NOTION_PARENT_PAGE_ID=
